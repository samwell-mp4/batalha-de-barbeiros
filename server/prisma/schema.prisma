// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- LEADS (importados de Google Maps) ---

model BarberLead {
  id              String    @id @default(uuid())
  name            String
  phone           String
  address         String
  rating          Float     @default(0)
  reviewCount     Int       @default(0)
  website         String?
  category        String?
  city            String
  citySlug        String?
  state           String    @default("MG")
  neighborhood    String?
  street          String?
  slug            String    @unique
  source          String    @default("google_maps")
  campaign        String?
  claimed         Boolean   @default(false)
  claimedAt       DateTime?
  claimedById     String?
  verified        Boolean   @default(false)
  verifiedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  claimedBy       User?     @relation(fields: [claimedById], references: [id])
}

// --- CORE MODULES ---

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String?
  avatar        String?   @db.Text
  bio           String?
  role          Role      @default(CLIENT)
  city          String?
  state         String?
  neighborhood  String?
  address       String?
  number        String?
  instagram     String?
  whatsapp      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  barberProfile Barber?
  appointments  Appointment[] @relation("ClientAppointments")
  likes         Like[]
  comments      Comment[]
  votes         Vote[]
  sentMessages    Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  matchLikes      MatchLike[]
  matchComments   MatchComment[]
  payments       Payment[] @relation("ClientPayments")
  claimedLeads    BarberLead[]
}

enum Role {
  CLIENT
  BARBER
  ADMIN
}

model Barber {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  barberShop    String
  slug          String?
  latitude      Float
  longitude     Float
  specialties   String[]
  workingHours  String?
  schedule      String?   @db.Text
  bio           String?
  rating        Float     @default(5.0)
  reviewsCount  Int       @default(0)
  isPremium     Boolean   @default(false)
  gallery       String[]
  isOnline      Boolean   @default(false)
  statsWins     Int       @default(0)
  statsLosses   Int       @default(0)
  followersCount Int     @default(0)
  servicesConfig String?   @db.Text
  pixKey        String?
  cityId        Int?
  neighborhoodId Int?

  // Relations
  city          City?         @relation(fields: [cityId], references: [id])
  neighborhood  Neighborhood? @relation(fields: [neighborhoodId], references: [id])
  appointments  Appointment[] @relation("BarberAppointments")
  posts         Post[]
  championships Championship[] @relation("BarberParticipants")
  payments      Payment[] @relation("BarberPayments")
}

model Appointment {
  id            String            @id @default(uuid())
  clientId      String
  client        User              @relation("ClientAppointments", fields: [clientId], references: [id])
  barberId      String?
  barber        Barber?           @relation("BarberAppointments", fields: [barberId], references: [id])
  date          DateTime
  time          String
  status        AppointmentStatus @default(PENDING)
  services      String[]
  price         Float             @default(0)
  paymentMethod String?
  isExpress     Boolean           @default(false)
  isQueue       Boolean           @default(false)
  latitude      Float?
  longitude     Float?
  createdAt     DateTime          @default(now())

  payment       Payment?
}

enum AppointmentStatus {
  PENDING
  PROPOSAL_SENT
  CONFIRMED
  ARRIVED
  IN_SERVICE
  PAYMENT
  COMPLETED
  CANCELLED
}

// --- LOCAL SEO ---

model State {
  id     Int    @id
  sigla  String @unique
  nome   String
  slug   String @unique
  cities City[]
}

model City {
  id            Int             @id // Código IBGE
  name          String
  slug          String
  stateId       Int
  state         State           @relation(fields: [stateId], references: [id])
  latitude      Float?
  longitude     Float?
  barbers_count Int             @default(0)
  avg_price     Float?
  top_services  String[]
  seo_enabled   Boolean         @default(false)
  neighborhoods Neighborhood[]
  barbers       Barber[]

  @@unique([stateId, slug])
}

model Neighborhood {
  id            Int      @id @default(autoincrement())
  name          String
  slug          String
  cityId        Int
  city          City     @relation(fields: [cityId], references: [id])
  barbers_count Int      @default(0)
  barbers       Barber[]

  @@unique([cityId, slug])
}

// --- PAGAMENTOS ---

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  CANCELLED
}

model Payment {
  id             String        @id @default(uuid())
  appointmentId  String        @unique
  appointment    Appointment   @relation(fields: [appointmentId], references: [id])
  clientId       String
  client         User          @relation("ClientPayments", fields: [clientId], references: [id])
  barberId       String
  barber         Barber        @relation("BarberPayments", fields: [barberId], references: [id])
  amount         Float
  fee            Float         @default(1.0)
  barberAmount   Float
  status         PaymentStatus @default(PENDING)
  mpPaymentId    Int?
  mpQrCode       String?       @db.Text
  mpQrCodeBase64 String?       @db.Text
  mpCopiaECola   String?       @db.Text
  pixKey         String?
  barberPixKey   String?
  mpTransferId   String?
  transferStatus String?       @default("PENDING")
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// --- MAP & REAL-TIME ---

model MapMarker {
  id          String   @id @default(uuid())
  title       String
  description String?
  latitude    Float
  longitude   Float
  type        MarkerType @default(SALON)
}

enum MarkerType {
  SALON
  ARENA
  EVENT
}

// --- SOCIAL FEED ---

model Post {
  id          String    @id @default(uuid())
  barberId    String
  barber      Barber    @relation(fields: [barberId], references: [id])
  content     String?
  imageUrl    String
  videoUrl    String?
  likesCount  Int       @default(0)
  createdAt   DateTime  @default(now())

  // Relations
  likes       Like[]
  comments    Comment[]
}

model Like {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
}

// --- LEAGUE ENGINE ---

model Championship {
  id              String             @id @default(uuid())
  name            String
  creatorId       String?
  ligaId          Int
  modality        String             @default("x1")
  theme           String?
  prize           String?
  votingTime      Int                @default(24)
  maxParticipants Int                @default(16)
  startDate       DateTime?
  startTime       String?
  status          ChampionshipStatus @default(OPEN)
  createdAt       DateTime           @default(now())

  // Relations
  participants    Barber[]           @relation("BarberParticipants")
  matches         Match[]
}

enum ChampionshipStatus {
  OPEN
  WAITING
  ONGOING
  FINISHED
}

model Match {
  id             String   @id @default(uuid())
  championshipId String
  championship   Championship @relation(fields: [championshipId], references: [id])
  round          Int      @default(1)
  player1Id      String?
  player2Id      String?
  photo1         String?
  photo2         String?
  score1         Float    @default(0)
  score2         Float    @default(0)
  winnerId       String?
  status         MatchStatus @default(PENDING)
  startedAt      DateTime?
  createdAt      DateTime @default(now())

  // Relations
  votes          Vote[]
  matchLikes     MatchLike[]
  matchComments  MatchComment[]
}

enum MatchStatus {
  PENDING
  LIVE
  FINISHED
}

model Vote {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  choiceId  String   // ID of the barber being voted for
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@unique([matchId, userId])
}

// --- CHAT ---

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

// --- MATCH LIKES & COMMENTS (persisted) ---

model MatchLike {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([matchId, userId])
}

model MatchComment {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
}
